# Supabase — Project Settings → API (and Settings → Database for the URL)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# New Supabase key naming (preferred); fall back to ANON_KEY for older projects.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy name (older Supabase projects) — only one of these two is needed.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-side only — keep secret. New naming is sb_secret_..., legacy is the "service_role" JWT.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...   # or eyJ... if legacy

# Direct Postgres connection (Drizzle migrations + server-side queries).
# Use the "Transaction pooler" connection string (port 6543) for serverless.
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email (Resend) — for transactional + abandoned cart emails
RESEND_API_KEY=
RESEND_FROM="Diesel Pro Brands <orders@dieselprobrands.com>"

# Scrapers — Apify (fridayparts + tamerx). Fab Heavy works without Apify.
APIFY_TOKEN=
APIFY_FRIDAYPARTS_DATASET_ID=
APIFY_TAMERX_DATASET_ID=

# Zoho — create OAuth client at https://api-console.zoho.com
# Required scopes: ZohoCRM.modules.contacts.ALL ZohoInventory.FullAccess.all ZohoBooks.fullaccess.all
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_DATA_CENTER=com
ZOHO_ORG_ID=
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAILS=admin@dieselprobrands.com
